# ─── Veritabanı (Railway MySQL) ─────────────────────────────────
# Bu değerleri Railway Dashboard > MySQL Plugin > Connect sekmesinden alın
DB_HOST=your-railway-host.railway.app
DB_PORT=3306
DB_NAME=railway
DB_USER=root
DB_PASS=your-railway-password

# ─── Yapay Zeka (Gemini) ──────────────────────────────────────────
# https://aistudio.google.com/app/apikey adresinden ücretsiz alabilirsiniz
GEMINI_API_KEY=your-gemini-api-key
